generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

model User {
  id                   String                 @id @default(cuid())
  name                 String?
  email                String?                @unique
  emailVerified        DateTime?
  image                String?

  accounts             Account[]
  sessions             Session[]
  memories             MemoryNode[]
  tasks                Task[]
  events               Event[]
  settings             UserSettings?
  calendarConfigs      CalendarConfig[]
  aiUsages             AiUsage[]
  cognitiveProfile     CognitiveProfile?
  memoryRelations      MemoryRelation[]
  dailyCognitiveStates DailyCognitiveState[]
  workingMemoryLogs    WorkingMemoryLog[]
  notes                Note[]
  thoughts             Thought[]
  courses              Course[]
  timelineMutationLogs TimelineMutationLog[]

  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String

  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model MemoryNode {
  id         String   @id @default(cuid())
  content    String
  category   String
  tags       String[]
  importance Float    @default(1.0)
  decayRate  Float    @default(0.01)
  sourceType     MemorySourceType? @default(EPISODIC)
  sourceId       String?
  indexingStatus String            @default("PENDING")
  indexedAt      DateTime?
  originType     String?
  originContext  String?
  visibility     String            @default("private") // private, ai-only, restricted, shareable
  taxonomy       String            @default("reflection") // reflection, stress-marker, recovery-event, deep-work-session, insight, planning
  contentHash    String?           @default("")
  reliability    Float             @default(1.0)
  memoryType     String            @default("hybrid") // episodic, semantic, hybrid

  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  embedding      MemoryEmbedding?

  createdAt      DateTime          @default(now())

  @@index([userId])
  @@index([sourceId, sourceType])
}

model Task {
  id          String   @id @default(cuid())
  title       String
  content     String?
  completed   Boolean  @default(false)
  dueDate     DateTime?

  userId      String
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Event {
  id            String   @id @default(cuid())
  title         String
  description   String?
  startTime     DateTime
  endTime       DateTime
  location      String?

  googleEventId String?

  calendarId    String
  calendar      CalendarConfig @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  userId        String
  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)

  courseSessionId String?
  courseSession   CourseSession? @relation(fields: [courseSessionId], references: [id], onDelete: Cascade)

  status        String?                @default("CONFIRMED")
  cancelledAt   DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, googleEventId])
  @@index([userId])
  @@index([userId, startTime])
  @@index([courseSessionId])
}

model UserSettings {
  id                     String   @id @default(cuid())

  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  theme                  String   @default("dark")

  aiModel                String   @default("maia/gemini-2.5-flash")
  aiMode                 String   @default("productivity")

  memoryDepth            Int      @default(10)

  productivityIntensity  String   @default("balanced")

  localAIEnabled         Boolean  @default(false)

  cognitiveThreshold     Int      @default(75)
  themeAccent            String   @default("lavender")
  autoSyncCalendar       Boolean  @default(true)
  autoDndFocus           Boolean  @default(true)

  isOnboarded            Boolean  @default(false)
  aiApiKey               String?

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

enum CognitiveCategoryType {
  GENERAL
  DEEP_WORK
  MEETING
  HEALTH
  RECOVERY
  ACADEMIC
  PERSONAL
  ADMIN
  PROJECT
}

model CalendarConfig {
  id                 String                @id @default(cuid())
  userId             String

  cognitiveCategory  String
  categoryType       CognitiveCategoryType @default(GENERAL)
  googleCalendarId   String

  description        String?
  color              String?

  isDefault          Boolean @default(false)
  isActive           Boolean @default(true)
  isSeededDefault    Boolean @default(false)
  deletedAt          DateTime?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  events             Event[]

  @@index([userId])
  @@index([userId, cognitiveCategory])
}

model AiUsage {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  model            String
  promptTokens     Int
  completionTokens Int
  estimatedCost    Float
  createdAt        DateTime @default(now())

  @@index([userId])
}

model MemoryEmbedding {
  id               String      @id @default(cuid())
  memoryNodeId     String      @unique
  memoryNode       MemoryNode  @relation(fields: [memoryNodeId], references: [id], onDelete: Cascade)

  embedding        Unsupported("vector(768)")
  embeddingModel   String      @default("text-embedding-004")
  embeddingVersion String      @default("v1")
  embeddingStatus  String      @default("completed") // pending, completed, failed
  lastEmbeddedAt   DateTime    @default(now())

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model MemoryRelation {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  sourceType        String   // memory, event, task, category, insight
  sourceId          String
  targetType        String   // memory, event, task, category, insight
  targetId          String

  relationType      String   // dependency, reference, overload, recovery, related
  relationStrength  Float    @default(0.5)
  relationConfidence Float   @default(1.0)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([sourceId, sourceType])
  @@index([targetId, targetType])
}

model CognitiveProfile {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  focusRhythm            Json?
  overloadTolerance      Float    @default(70.0)
  recoveryQuality        Float    @default(50.0)
  productivityConsistency Float    @default(50.0)
  deepWorkTiming         String?
  procrastinationIndex   Float    @default(0.0)
  stressCycles           Json?

  focusTrend             Json?
  stressTrend            Json?
  recoveryTrend          Json?

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model DailyCognitiveState {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  date                  DateTime
  cognitiveLoad         Float
  focusMinutes          Int
  recoveryMinutes       Int
  burnoutRisk           String
  contextSwitches       Int
  focusFragmentation    Float
  confidenceScore       Float?   @default(1.0)

  createdAt             DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
}

model WorkingMemoryLog {
  id                      String   @id @default(cuid())
  executionId             String   @unique
  userId                  String
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId               String
  finalStage              String   // initialized, retrieval_staging, reasoning, reflection, completed, failed
  userInputLength         Int      // length of user input characters
  tokenBudget             Int
  promptTokens            Int      @default(0)
  completionTokens        Int      @default(0)
  totalTokens             Int      @default(0)
  latencyMs               Int      @default(0)
  schemaVersion           Int      @default(1)
  
  // Retry Semantics
  retrievalRetryCount     Int      @default(0)
  reflectionRetryCount    Int      @default(0)
  gatewayRetryCount       Int      @default(0)
  orchestrationRetryCount Int      @default(0)
  
  confidenceScore         Float    @default(1.0)
  reflectionStatus        String   @default("none") // e.g. success, corrected, bypassed
  
  // Observability & explainable retrieval traces (no raw contents)
  retrievalTrace          Json?    // e.g. { selected: [{ id, category, score, type }], discarded: [{ id, category, score, reason }] }
  
  executionSource         String   // chat_api, worker_job, etc.
  cleanupReason           String   // completed, failed, stale_timeout, etc.
  createdAt               DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
}

enum MemorySourceType {
  NOTE
  THOUGHT
  EPISODIC
  SYSTEM
  INFERRED
}

model Note {
  id         String    @id @default(cuid())
  title      String
  content    String    @db.Text
  category   String    @default("Ideas") // Ideas, References, Reminders
  notebook   String    @default("Personal") // Personal, Research, Academics
  tags       String[]
  isArchived Boolean   @default(false)
  deletedAt  DateTime?

  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
}

model Thought {
  id                String    @id @default(cuid())
  content           String    @db.Text
  tags              String[]
  visibility        String    @default("PRIVATE")
  retrievalEligible Boolean   @default(true)
  isArchived        Boolean   @default(false)
  deletedAt         DateTime?

  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
}

enum CourseSessionType {
  CLASS
  QUIZ
  MID_EXAM
  FINAL_EXAM
  PRESENTATION
  LAB
  PROJECT_REVIEW
  SEMINAR
  REPLACEMENT
  HOLIDAY
  CUSTOM
}

enum CourseSessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
  SKIPPED
}

enum CourseSessionMode {
  ONLINE
  OFFLINE
  HYBRID
}

enum SessionProgressState {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  PARTIALLY_COMPLETED
  POSTPONED
  CANCELLED
  SKIPPED
}

enum TimelineMutationType {
  OVERRIDE
  RESCHEDULE
  SHIFT_FORWARD
  SHIFT_BACKWARD
  CANCEL
  SKIP
  MODE_CHANGE
  ROOM_CHANGE
  SEQUENCE_REBUILD
  SESSION_COMPLETED
  SESSION_PARTIAL
  SESSION_POSTPONED
  SESSION_SKIPPED
  SESSION_REOPENED
  SESSION_PROGRESS_UPDATED
  SEQUENCE_SHIFT
  REPLACEMENT_SESSION_CREATED
  OVERRIDE_SESSION
}

enum Weekday {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

model Course {
  id                 String                @id @default(cuid())
  userId             String
  title              String
  lecturer           String
  semester           Int
  academicYear       String
  totalSessions      Int
  categoryType       CognitiveCategoryType @default(ACADEMIC)
  defaultSessionMode CourseSessionMode     @default(OFFLINE)
  defaultLocation    String?
  defaultMeetingLink String?
  timelineVersion    Int                   @default(1)
  normalWeekday      Weekday               @default(MONDAY)
  deletedAt          DateTime?

  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions           CourseSession[]
  mutationLogs       TimelineMutationLog[]

  @@index([userId])
}

model CourseSession {
  id                  String               @id @default(cuid())
  courseId            String
  sequenceNumber      Int
  sessionType         CourseSessionType    @default(CLASS)
  plannedDate         DateTime
  actualDate          DateTime?
  startTime           String               // Format: "HH:MM"
  endTime             String               // Format: "HH:MM"
  status              CourseSessionStatus  @default(SCHEDULED)
  sessionMode         CourseSessionMode
  room                String?
  meetingLink         String?
  notes               String?
  deletedAt           DateTime?

  progressState       SessionProgressState @default(NOT_STARTED)
  progressPercentage  Int                  @default(0)
  completedAt         DateTime?
  actualStartTime     DateTime?
  actualEndTime       DateTime?
  executionNotes      String?
  executionMetadata   Json?
  wasActuallyHeld     Boolean              @default(false)

  isReplacement       Boolean              @default(false)
  replacementForId    String?
  replacementFor      CourseSession?       @relation("ReplacementSessions", fields: [replacementForId], references: [id], onDelete: SetNull)
  replacements        CourseSession[]      @relation("ReplacementSessions")

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  course              Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  events              Event[]
  mutationLogs        TimelineMutationLog[]

  @@index([courseId])
  @@index([courseId, sequenceNumber])
}

model TimelineMutationLog {
  id                String               @id @default(cuid())
  userId            String
  courseId          String
  courseSessionId   String?
  mutationType      TimelineMutationType
  affectedSequences Int[]
  previousState     Json?
  newState          Json?
  reason            String?
  createdAt         DateTime             @default(now())

  actorUserId       String?
  actorType         String?              @default("USER") // e.g. "USER", "SYSTEM", "CRON"
  triggerSource     String?              @default("WEB_INTERFACE") // e.g. "WEB_INTERFACE", "API", "MUTATION_SHIFTER"

  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  course            Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseSession     CourseSession?       @relation(fields: [courseSessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([courseId])
  @@index([courseSessionId])
}